GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/callback
SESSION_SECRET=your-session-secret
GOOGLE_ALLOWED_DOMAIN=yourdomain.org

# Optional: comma-separated list of individual email addresses to allow (in addition to the domain above)
# GOOGLE_ALLOWED_EMAILS=person@gmail.com,another@gmail.com

# Optional: override the volume path (defaults to ./volume)
# VOLUME_PATH=./volume

# Optional: Google service account credentials JSON (single-line) for creating Google Docs
# Required for the "Create Google Doc" feature
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: Anthropic API key for AI-powered song suggestions
# When set, a "Get Song Suggestions" option will appear after creating a new playlist
# ANTHROPIC_API_KEY=sk-ant-...
